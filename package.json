    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.27",
    "husky": "^9.1.7",
    "lovable-tagger": "^1.1.7",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
