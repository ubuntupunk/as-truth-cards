// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id                      Int       @id @default(autoincrement())
  createdAt              DateTime  @default(now()) @map("created_at")
  title                  String
  frontDescription       String    @map("front_description")
  backDescription        String    @map("back_description")
  symbol                 String
  imageUrl              String?   @map("image_url")
  tags                   String[]
  includedInPalestineStack Boolean  @default(false) @map("included_in_palestine_stack")
  isFeatured             Boolean   @default(false) @map("is_featured")
  sources                Json?
  interactions           UserInteraction[]

  @@map("cards")
}

model UserInteraction {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now()) @map("created_at")
  userId          String?  @map("user_id")
  cardId          Int      @map("card_id")
  interactionType String   @map("interaction_type")
  feedbackRating  Int?     @map("feedback_rating")
  feedbackText    String?  @map("feedback_text")
  card            Card     @relation(fields: [cardId], references: [id])

  @@map("user_interactions")
}
