{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "moduleResolution": "Node",
      "esModuleInterop": true,
      "allowJs": true,
      "checkJs": true,
      "strict": true,
      "skipLibCheck": true,
      "noEmit": true
    },
    "include": ["*.ts"],
    "ts-node": {
      "esm": true,
      "experimentalSpecifierResolution": "node"
    }
  }
  