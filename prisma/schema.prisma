// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

// Truth Cards
model Card {
  id                       Int               @id @default(autoincrement())
  createdAt                DateTime          @default(now()) @map("created_at")
  title                    String
  frontDescription         String            @map("front_description")
  backDescription          String            @map("back_description")
  symbol                   String
  imageUrl                 String?           @map("image_url")
  tags                     String[]
  includedInPalestineStack Boolean           @default(false) @map("included_in_palestine_stack")
  isFeatured               Boolean           @default(false) @map("is_featured")
  sources                  Json?
  interactions             UserInteraction[]

  @@map("cards")
}

// User Roles - stored separately from Stack Auth's users_sync table
enum UserRole {
  ANONYMOUS   // Basic view access only
  VERIFIED    // Email verified users - limited interaction
  ACADEMIC    // Academic institutions
  RESEARCHER  // Verified researchers
  MODERATOR   // Can moderate comments
  ADMIN       // Full access
}

// User Profile - links to Stack Auth user by ID
model UserProfile {
  id            String    @id  // Stack Auth user ID
  role          UserRole  @default(ANONYMOUS)
  bio           String?
  website       String?
  location      String?
  avatar        String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("user_profiles")
}

// User Interactions with Cards
model UserInteraction {
  id              Int             @id @default(autoincrement())
  createdAt       DateTime        @default(now()) @map("created_at")
  userId          String?         @map("user_id")
  cardId          Int             @map("card_id")
  interactionType InteractionType
  feedbackRating  Int?
  feedbackText    String?
  status          ContentStatus   @default(PENDING)
  ipAddress       String?
  card            Card            @relation(fields: [cardId], references: [id])

  @@index([status, createdAt])
  @@index([userId, interactionType])
  @@map("user_interactions")
}

enum ContentStatus {
  PENDING
  APPROVED
  FLAGGED
  REJECTED
  REMOVED
}

enum InteractionType {
  VIEW
  SHARE
  RATING_UP
  RATING_DOWN
  STRUCTURED_FEEDBACK
  ACADEMIC_FEEDBACK
  MODERATION_ACTION
}
